* { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }
body { background-color: #f0f2f5; }

/* Headers */
.big-header { background-color: #004a99; color: white; padding: 40px; text-align: center; margin-bottom: 50px; }
.welcome-msg { text-align: center; font-size: 24px; margin-bottom: 30px; color: #333; }

/* Forms */
.form-box { max-width: 500px; margin: 0 auto; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
.form-group { margin-bottom: 15px; }
.form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
.form-group input, .form-group select, .form-group textarea { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; }

button { width: 100%; padding: 12px; background: #28a745; color: white; border: none; cursor: pointer; border-radius: 5px; font-size: 16px; }
button:hover { background: #218838; }

.toggle-btn { text-align: center; color: #004a99; cursor: pointer; margin-top: 15px; text-decoration: underline; }

/* Dashboards */
.navbar { display: flex; justify-content: space-between; align-items: center; background: #004a99; color: white; padding: 20px; }
.container { padding: 30px; max-width: 1200px; margin: 0 auto; }

/* Status Badges */
.status { padding: 5px 10px; border-radius: 15px; font-size: 12px; font-weight: bold; color: white; }
.resolve { background: #28a745; }
.review { background: #ffc107; color: black; }
.assign { background: #17a2b8; }

/* Complaint List */
.complaint-card { background: white; padding: 15px; margin-bottom: 10px; border-radius: 5px; border-left: 5px solid #004a99; cursor: pointer; }